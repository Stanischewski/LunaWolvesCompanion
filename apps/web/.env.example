# ============================================================
# Luna Wolves — Web Umgebungsvariablen (CT 204)
# Luna Wolves — Web Environment Variables (CT 204)
# ============================================================
# Diese Datei nach /opt/lunawolves/apps/web/.env kopieren
# und alle Platzhalter (<...>) durch echte Werte ersetzen.
#
# Copy this file to /opt/lunawolves/apps/web/.env
# and replace all placeholders (<...>) with real values.
#
# Lokal: Datei als .env.local ablegen — wird von Next.js
# automatisch geladen und von Git ignoriert.
# Local: save as .env.local — loaded automatically by Next.js
# and ignored by Git.
# ============================================================

# --- Anwendung / Application ---
NODE_ENV=production

# --- API-URLs ---
# Interne URL zum API-Container (nur serverseitig verwendet)
# Internal URL to the API container (server-side only)
API_URL=http://10.10.10.202:3001
# Öffentliche URL für den Browser (Client Components, Socket.IO)
# Public URL for the browser (Client Components, Socket.IO)
NEXT_PUBLIC_API_URL=https://<DEINE_DOMAIN>

# --- Gilde / Guild ---
# Name der Gilde für Roster und Stats.
# Leer lassen = erste Gilde des eingeloggten Spielers (oder erste in der DB).
# Name of the guild for roster and stats.
# Leave empty = first guild of the logged-in player (or first in the DB).
GUILD_NAME=<GILDENNAME>
