# Discord Bot Token (aus dem Discord Developer Portal)
DISCORD_BOT_TOKEN=your-bot-token-here

# Discord Server ID (Rechtsklick auf Server → ID kopieren)
DISCORD_GUILD_ID=your-server-id-here

# Internes API-Secret (muss mit BOT_SECRET in apps/api/.env übereinstimmen)
BOT_SECRET=change-me-to-a-random-secret

# URL der lw-api (intern: http://10.10.10.202:3001, lokal: http://localhost:3001)
API_URL=http://localhost:3001

# UUID der "Luna Wolves"-Gilde in der PostgreSQL-Datenbank
# Abrufen mit: GET /api/v1/guilds (nach dem ersten Start der API)
LUNA_GUILD_ID=your-guild-uuid-here
