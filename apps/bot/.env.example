# ============================================================
# Luna Wolves — Bot Umgebungsvariablen (CT 203)
# Luna Wolves — Bot Environment Variables (CT 203)
# ============================================================
# Diese Datei nach /opt/lunawolves/apps/bot/.env kopieren
# und alle Platzhalter (<...>) durch echte Werte ersetzen.
#
# Copy this file to /opt/lunawolves/apps/bot/.env
# and replace all placeholders (<...>) with real values.
# ============================================================

# --- Discord ---
# Zugangsdaten aus: https://discord.com/developers/applications
# Credentials from: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=<BOT_TOKEN>
DISCORD_GUILD_ID=<SERVER_ID>

# --- Interne Kommunikation / Internal Communication ---
# URL des API-Containers
# URL of the API container
API_URL=http://10.10.10.202:3001
# Gemeinsames Secret mit der API (muss mit BOT_SECRET in apps/api/.env übereinstimmen)
# Shared secret with the API (must match BOT_SECRET in apps/api/.env)
BOT_SECRET=<ZUFALLSSTRING>

# --- Gilde / Guild ---
# UUID der Gilde in der Datenbank
# Abrufen mit: GET /api/v1/guilds (nach dem ersten Start der API)
# UUID of the guild in the database
# Retrieve with: GET /api/v1/guilds (after the first API start)
LUNA_GUILD_ID=<GUILD_UUID>

# --- Discord Channels ---
# Rechtsklick auf den Channel → ID kopieren (Entwicklermodus muss aktiv sein)
# Right-click the channel → Copy ID (Developer Mode must be enabled)
RAID_CHANNEL_ID=<CHANNEL_ID>
OFFICER_CHANNEL_ID=<CHANNEL_ID>
