# ============================================================
# Luna Wolves — API Umgebungsvariablen (CT 202)
# Luna Wolves — API Environment Variables (CT 202)
# ============================================================
# Diese Datei nach /opt/lunawolves/apps/api/.env kopieren
# und alle Platzhalter (<...>) durch echte Werte ersetzen.
#
# Copy this file to /opt/lunawolves/apps/api/.env
# and replace all placeholders (<...>) with real values.
# ============================================================

# --- Anwendung / Application ---
NODE_ENV=production
PORT=3001

# --- PostgreSQL (CT 200) ---
# Admin-Verbindung für Migrationen (Drizzle Kit)
# Admin connection for migrations (Drizzle Kit)
DATABASE_ADMIN_URL=postgresql://lw_admin:<PASSWORT>@10.10.10.200:5432/lunawolves
# App-Verbindung für den API-Betrieb
# App connection for the API
DATABASE_URL=postgresql://lw_app:<PASSWORT>@10.10.10.200:5432/lunawolves

# --- Redis (CT 201) ---
REDIS_URL=redis://:<PASSWORT>@10.10.10.201:6379

# --- Battle.net OAuth2 ---
# Zugangsdaten aus: https://develop.battle.net/access/clients
# Credentials from: https://develop.battle.net/access/clients
BNET_CLIENT_ID=<CLIENT_ID>
BNET_CLIENT_SECRET=<CLIENT_SECRET>
BNET_CALLBACK_URL=https://<DEINE_DOMAIN>/auth/bnet/callback
BNET_REGION=eu

# --- Discord OAuth2 & Bot (CT 203) ---
# Zugangsdaten aus: https://discord.com/developers/applications
# Credentials from: https://discord.com/developers/applications
DISCORD_CLIENT_ID=<CLIENT_ID>
DISCORD_CLIENT_SECRET=<CLIENT_SECRET>
DISCORD_CALLBACK_URL=https://<DEINE_DOMAIN>/auth/discord/callback
DISCORD_BOT_TOKEN=<BOT_TOKEN>
DISCORD_GUILD_ID=<SERVER_ID>

# Gemeinsames Secret zwischen API und Bot (beliebiger Zufallsstring)
# Shared secret between API and bot (any random string)
BOT_SECRET=<ZUFALLSSTRING>

# --- JWT ---
# Lange Zufallsstrings verwenden, z.B.: openssl rand -hex 64
# Use long random strings, e.g.: openssl rand -hex 64
JWT_SECRET=<ZUFALLSSTRING>
JWT_REFRESH_SECRET=<ZUFALLSSTRING>

# --- Interne URLs / Internal URLs ---
# URL des Web-Containers (für Weiterleitungen nach OAuth)
# URL of the web container (for post-OAuth redirects)
FRONTEND_URL=https://<DEINE_DOMAIN>
WEB_BASE_URL=http://10.10.10.204:3000
API_BASE_URL=http://10.10.10.202:3001
