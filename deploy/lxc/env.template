# ============================================================
# Luna Wolves — Environment Variables
# ============================================================
# Diese Datei nach /opt/lunawolves/.env kopieren
# auf den jeweiligen Containern (CT 202, 203, 204).
#
# Werte aus den Credential-Dateien der DB/Redis Container
# übernehmen!
# ============================================================

# --- App ---
NODE_ENV=development
PORT=3000

# --- PostgreSQL (CT 200) ---
# Admin-URL für Migrations (Drizzle Kit)
DATABASE_ADMIN_URL=postgresql://lw_admin:HIER_ADMIN_PASSWORT@10.10.10.200:5432/lunawolves
# App-URL für API-Zugriff
DATABASE_URL=postgresql://lw_app:HIER_APP_PASSWORT@10.10.10.200:5432/lunawolves

# --- Redis (CT 201) ---
REDIS_URL=redis://:HIER_REDIS_PASSWORT@10.10.10.201:6379

# --- Battle.net OAuth2 ---
# https://develop.battle.net/access/clients
BNET_CLIENT_ID=
BNET_CLIENT_SECRET=
BNET_REDIRECT_URI=https://deine-domain.de/auth/callback

# --- Discord Bot (nur für CT 203) ---
# https://discord.com/developers/applications
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

# --- JWT ---
JWT_SECRET=HIER_LANGEN_ZUFALLSSTRING_GENERIEREN
JWT_REFRESH_SECRET=HIER_ANDEREN_ZUFALLSSTRING

# --- API URLs (interne Kommunikation) ---
API_BASE_URL=http://10.10.10.202:3000
WEB_BASE_URL=http://10.10.10.204:3000
